generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  student
  tutor
  manager
}

enum SubjectFocus {
  maths
  english
  both
}

enum SheetType {
  worksheet
  quiz
  practice
}

enum LessonPlanStatus {
  active
  completed
  draft
}

enum LessonPlanItemStatus {
  locked
  available
  in_progress
  completed
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String        @map("password_hash")
  name         String
  role         Role
  age          Int?
  subjectFocus SubjectFocus? @map("subject_focus")
  createdAt    DateTime      @default(now()) @map("created_at")

  studentPlans     LessonPlan[]        @relation("StudentPlans")
  tutorPlans       LessonPlan[]        @relation("TutorPlans")
  studentResponses StudentResponse[]
  lessonDays       StudentLessonDay[]

  @@map("users")
}

model StudentLessonDay {
  id        Int @id @default(autoincrement())
  studentId Int @map("student_id")
  dayOfWeek Int @map("day_of_week") // 0=Monday, 1=Tuesday, ..., 6=Sunday

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, dayOfWeek])
  @@map("student_lesson_days")
}

model Sheet {
  id              Int       @id @default(autoincrement())
  title           String
  subject         String
  topic           String
  difficultyLevel Int       @map("difficulty_level")
  contentJson     Json      @map("content_json")
  sheetType       SheetType @map("sheet_type")
  tags            String[]
  createdAt       DateTime  @default(now()) @map("created_at")

  lessonPlanItems      LessonPlanItem[]
  studentResponses     StudentResponse[]
  sourceRules          FollowUpRule[]   @relation("SourceRules")
  followUpRules        FollowUpRule[]   @relation("FollowUpRules")
  sourceFollowUpLogs   FollowUpLog[]    @relation("SourceLogs")
  followUpFollowUpLogs FollowUpLog[]    @relation("FollowUpLogs")

  @@map("sheets")
}

model LessonPlan {
  id              Int              @id @default(autoincrement())
  studentId       Int              @map("student_id")
  tutorId         Int              @map("tutor_id")
  title           String
  startDate       DateTime?        @map("start_date")
  status          LessonPlanStatus @default(draft)
  lessonDayOfWeek Int?             @map("lesson_day_of_week")
  boardUuid       String?          @map("board_uuid")
  studentNotes    String?          @map("student_notes")
  createdAt       DateTime         @default(now()) @map("created_at")

  student      User             @relation("StudentPlans", fields: [studentId], references: [id])
  tutor        User             @relation("TutorPlans", fields: [tutorId], references: [id])
  items        LessonPlanItem[]
  sessions     LessonSession[]
  followUpLogs FollowUpLog[]

  @@map("lesson_plans")
}

model LessonSession {
  id           Int       @id @default(autoincrement())
  lessonPlanId Int       @map("lesson_plan_id")
  scheduledAt  DateTime  @map("scheduled_at")
  attendedAt   DateTime? @map("attended_at")
  durationMins Int?      @map("duration_mins")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")

  lessonPlan LessonPlan @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@map("lesson_sessions")
}

model LessonPlanItem {
  id            Int                  @id @default(autoincrement())
  lessonPlanId  Int                  @map("lesson_plan_id")
  sheetId       Int?                 @map("sheet_id")
  sequenceOrder Int                  @map("sequence_order")
  scheduledDate DateTime?            @map("scheduled_date")
  status        LessonPlanItemStatus @default(locked)
  dueDate       DateTime?            @map("due_date")
  autoGenerated Boolean              @default(false) @map("auto_generated")
  tutorNotes    String?              @map("tutor_notes")
  // For non-sheet items (IXL, paper activity, custom task): title + type
  customTitle   String?              @map("custom_title")
  customType    String?              @map("custom_type") // e.g. "ixl_maths", "ixl_english", "paper", "other"
  createdAt     DateTime             @default(now()) @map("created_at")

  lessonPlan       LessonPlan        @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)
  sheet            Sheet?            @relation(fields: [sheetId], references: [id])
  studentResponses StudentResponse[]

  @@map("lesson_plan_items")
}

model StudentResponse {
  id               Int       @id @default(autoincrement())
  studentId        Int       @map("student_id")
  sheetId          Int       @map("sheet_id")
  lessonPlanItemId Int       @map("lesson_plan_item_id")
  responsesJson    Json      @map("responses_json")
  score            Float?
  completedAt      DateTime? @map("completed_at")
  timeSpentSeconds Int?      @map("time_spent_seconds")
  createdAt        DateTime  @default(now()) @map("created_at")

  student        User           @relation(fields: [studentId], references: [id])
  sheet          Sheet          @relation(fields: [sheetId], references: [id])
  lessonPlanItem LessonPlanItem @relation(fields: [lessonPlanItemId], references: [id])

  @@map("student_responses")
}

model FollowUpRule {
  id               Int      @id @default(autoincrement())
  triggerCondition String   @map("trigger_condition")
  sourceSheetId    Int      @map("source_sheet_id")
  followUpSheetId  Int      @map("follow_up_sheet_id")
  priority         Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_at")

  sourceSheet   Sheet       @relation("SourceRules", fields: [sourceSheetId], references: [id])
  followUpSheet Sheet       @relation("FollowUpRules", fields: [followUpSheetId], references: [id])
  followUpLogs  FollowUpLog[]

  @@map("follow_up_rules")
}

model FollowUpLog {
  id              Int      @id @default(autoincrement())
  lessonPlanId    Int      @map("lesson_plan_id")
  studentId       Int      @map("student_id")
  triggerRuleId   Int      @map("trigger_rule_id")
  sourceSheetId   Int      @map("source_sheet_id")
  followUpSheetId Int      @map("follow_up_sheet_id")
  studentScore    Float    @map("student_score")
  createdAt       DateTime @default(now()) @map("created_at")

  lessonPlan    LessonPlan   @relation(fields: [lessonPlanId], references: [id])
  triggerRule   FollowUpRule @relation(fields: [triggerRuleId], references: [id])
  sourceSheet   Sheet        @relation("SourceLogs", fields: [sourceSheetId], references: [id])
  followUpSheet Sheet        @relation("FollowUpLogs", fields: [followUpSheetId], references: [id])

  @@map("follow_up_logs")
}
